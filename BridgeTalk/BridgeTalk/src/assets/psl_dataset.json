{
  "language": "PSL",
  "version": "1.0",
  "description": "Pakistan Sign Language dataset for Bridge Talk",
  "alphabet": {
    "A": "assets/psl_gifs/A.svg",
    "B": "assets/psl_gifs/B.svg",
