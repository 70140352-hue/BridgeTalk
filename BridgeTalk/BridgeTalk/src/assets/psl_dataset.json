  "words": {
    "hello": {
      "type": "word",
      "letters": "HELLO",
      "description": "Wave hand side to side at head level"
    },
    "goodbye": {
      "type": "word",
      "letters": "GOODBYE",
      "description": "Wave hand from inside outward"
    },
    "please": {
      "type": "word",
      "letters": "PLEASE",
      "description": "Circular motion on chest"
    },
    "thank you": {
      "type": "word",
      "letters": "THANK YOU",
      "description": "Flat hand from chin moving forward"
    },
    "sorry": {
      "type": "word",
      "letters": "SORRY",
      "description": "Fist circled on chest"
    },
    "yes": {
      "type": "word",
      "letters": "YES",
      "description": "Fist nodding up and down"
    },
    "no": {
      "type": "word",
      "letters": "NO",
      "description": "Index and middle finger tap thumb twice"
    },
    "help": {
      "type": "word",
      "letters": "HELP",
      "description": "Thumbs up lifted by other hand"
    },
    "water": {
      "type": "word",
      "letters": "WATER",
      "description": "W hand taps chin twice"
    },
    "food": {
      "type": "word",
      "letters": "FOOD",
      "description": "Fingers to mouth twice"
    },
    "home": {
      "type": "word",
      "letters": "HOME",
      "description": "Fingertips to cheek, then move to temple"
    },
    "school": {
      "type": "word",
      "letters": "SCHOOL",
      "description": "Clap hands twice"
    },
    "family": {
      "type": "word",
      "letters": "FAMILY",
      "description": "F hands circle around"
    },
    "friend": {
      "type": "word",
      "letters": "FRIEND",
      "description": "Hook index fingers together"
    },
    "love": {
      "type": "word",
      "letters": "LOVE",
      "description": "Cross arms over chest"
    },
    "good": {
      "type": "word",
      "letters": "GOOD",
      "description": "Flat hand from chin forward"
    },
    "bad": {
      "type": "word",
      "letters": "BAD",
      "description": "Flat hand flips down from chin"
    },
    "big": {
      "type": "word",
      "letters": "BIG",
      "description": "L hands move apart"
    },
    "small": {
      "type": "word",
      "letters": "SMALL",
      "description": "Flat hands move together"
    },
    "hot": {
      "type": "word",
      "letters": "HOT",
      "description": "Claw hand twists away from mouth"
    },
    "cold": {
      "type": "word",
      "letters": "COLD",
      "description": "Fists shake near shoulders"
    },
    "mother": {
      "type": "word",
      "letters": "MOTHER",
      "description": "Thumb of 5-hand taps chin"
    },
    "father": {
      "type": "word",
      "letters": "FATHER",
      "description": "Thumb of 5-hand taps forehead"
    },
    "doctor": {
      "type": "word",
      "letters": "DOCTOR",
      "description": "D hand taps wrist"
    },
    "hospital": {
      "type": "word",
      "letters": "HOSPITAL",
      "description": "H hand draws cross on arm"
    }
  },
  "phrases": {
    "my name is": "Point to self, then spell name",
    "how are you": "How sign + you point",
    "i am fine": "Point self + F hand on chest",
    "nice to meet you": "Nice + meet + you",
    "where is": "W hand + location point",
    "i need help": "Point self + need + help sign",
    "i don't understand": "Point self + twist hand near head",
    "please repeat": "Please + R hands circle",
    "speak slowly": "Slow sign + speak"
  },
  "fingerspelling_note": "PSL uses fingerspelling for proper nouns and words without established signs"
}